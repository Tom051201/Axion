# Axion Engine - Submesh Test Cube
# This cube is 2x2x2 units and is split into two distinct submeshes.

# --- 8 Vertices ---
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v -1.0  1.0  1.0
v  1.0  1.0  1.0
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v -1.0  1.0 -1.0
v  1.0  1.0 -1.0

# --- 4 Texture Coordinates (UVs) ---
vt 0.0 0.0
vt 1.0 0.0
vt 0.0 1.0
vt 1.0 1.0

# --- 6 Normals (One for each face) ---
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# ==========================================
# SUBMESH 0: The Body (Sides and Bottom)
# ==========================================
g CubeBody
usemtl Material_Body

# Front Face
f 1/1/1 2/2/1 4/4/1
f 1/1/1 4/4/1 3/3/1
# Back Face
f 6/1/2 5/2/2 7/4/2
f 6/1/2 7/4/2 8/3/2
# Bottom Face
f 5/1/4 6/2/4 2/4/4
f 5/1/4 2/4/4 1/3/4
# Right Face
f 2/1/5 6/2/5 8/4/5
f 2/1/5 8/4/5 4/3/5
# Left Face
f 5/1/6 1/2/6 3/4/6
f 5/1/6 3/4/6 7/3/6

# ==========================================
# SUBMESH 1: The Top Face
# ==========================================
g CubeTop
usemtl Material_Top

# Top Face
f 3/1/3 4/2/3 8/4/3
f 3/1/3 8/4/3 7/3/3
